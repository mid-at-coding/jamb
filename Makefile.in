CC=@CC@
LD=@CC@
CFLAGS=@CFLAGS@ @glib_CFLAGS@ @json_CFLAGS@ -DPACKAGE_VERSION=@PACKAGE_VERSION@
LDFLAGS=@LDFLAGS@
LIBS=@LIBS@ @glib_LIBS@ @json_LIBS@
JAMB_OBJS=build/jamb.o build/errorcode.o build/state.o build/player_manager.o build/player.o build/sqlite.o
OBJS=build/sqlite.o
PLAYER_MAKEFILES=players/miniaudio/Makefile

.PHONY: clean all tags

all: build/jamb players

build/jamb: $(JAMB_OBJS)
	$(LD) -Iinc/ -Isqlite/ -o $@ $^ $(LDFLAGS) $(LIBS)

build/%.o: src/%.c inc/errorcode.h
	$(CC) -Iinc/ -Isqlite/ $< $(CFLAGS) -c -o $@

build/sqlite.o:
	$(CC) sqlite/sqlite3.c -c -o $@ $(CFLAGS)

doc/jamb.1: doc/ttman doc/jamb.txt
	./doc/ttman doc/jamb.txt $@

doc/ttman: doc/ttman.c
	$(CC) doc/ttman.c -o doc/ttman

compile_commands.json: Makefile
	compiledb -n make # can also use bear -- make -B

players: $(PLAYER_MAKEFILES) $(OBJS)
	make -C players/miniaudio

clean:
	rm -f build/jamb build/*.o

tags:
	ctags src/*.c
